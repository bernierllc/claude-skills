{
  "$schema": "https://bernierllc.com/schemas/hooks/v1.json",
  "version": "3.3.0",
  "hooks": [
    {
      "id": "vw-scan-on-edit",
      "event": "on_file_edit",
      "command": "aec run-script verification-writer scan-versions.py --root . --current-version 3.3.0 --quiet",
      "description": "After frontend/UI file changes, scan verification docs for staleness. Flags stale docs so the agent can update them while still in context.",
      "match": "*.tsx|*.ts|*.jsx|*.js|*.html|*.htm|*.css|*.scss|*.sass|*.less|*.vue|*.svelte|*.astro|*.ejs|*.hbs|*.handlebars|*.pug|*.jade|*.njk|*.twig|*.liquid|*.erb|*.py|*.kt|*.swift|*.dart|*.xml",
      "blocking": false,
      "timeout_ms": 10000,
      "when": {
        "repo_has": ["docs/verification"]
      }
    },
    {
      "id": "vw-route-scan-on-edit",
      "event": "on_file_edit",
      "command": "aec run-script verification-writer route-scanner.py",
      "description": "After route/screen file changes, re-scan routes to detect new or removed pages that need verification docs.",
      "match": "app/**/*.tsx|app/**/*.ts|app/**/*.jsx|app/**/*.js|pages/**/*.tsx|pages/**/*.ts|pages/**/*.jsx|pages/**/*.js|src/routes/**/*|src/pages/**/*|src/screens/**/*|src/views/**/*|templates/**/*.html|templates/**/*.py",
      "blocking": false,
      "timeout_ms": 10000,
      "when": {
        "repo_has_any": ["app", "pages", "src/routes", "src/pages", "src/screens", "src/views", "templates"]
      }
    }
  ]
}
